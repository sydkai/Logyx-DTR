# Copy to .env for local development

PORT=3001
HOST=127.0.0.1

# Cloud (Render) — set in dashboard
# HOST=0.0.0.0
# NODE_ENV=production
# CLIENT_ORIGIN=https://logyx-dtr.onrender.com
# DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# Local desktop app (Electron) — omit DATABASE_URL to use SQLite
# SQLITE_PATH=C:\path\to\logyx.db

JWT_SECRET=logyx-dev-secret-change-in-production
