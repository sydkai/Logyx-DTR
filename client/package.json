{
  "name": "logyx-dtr",
  "private": true,
  "version": "1.2.0",
  "description": "Logyx Daily Time Record - Attendance scanning application",
  "author": "Logyx Systems",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:standalone": "cross-env VITE_BASE=/ vite build",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "preelectron:build": "node scripts/prebuild-clean.js",
    "electron:build": "npm run build:db --prefix ../server && cross-env VITE_BASE=./ vite build && electron-builder --config.directories.output=release-build",
    "electron:build:clean": "node scripts/prebuild-clean.js && npm run electron:build",
    "build:db": "npm run build:db --prefix ../server"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "jsbarcode": "^3.12.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.Logyx-Systems.logyx-dtr",
    "productName": "Logyx Daily Time Record",
    "icon": "public/icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/icon.ico"
    ],
    "extraResources": [
      {
        "from": "../server",
        "to": "server",
        "filter": ["**/*", "!.env", "!*.log"]
      },
      {
        "from": "../data/logyx.db",
        "to": "data/logyx.db"
      },
      {
        "from": "dist",
        "to": "client/dist"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}